generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  shoes        Shoe[]
  workouts     Workout[]

  @@map("users")
}

enum WorkoutType {
  RUNNING
  WALKING
}

model Shoe {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  photoUrl        String   @map("photo_url") @db.VarChar(2048)
  brandName       String   @map("brand_name") @db.VarChar(75)
  shoeName        String   @map("shoe_name") @db.VarChar(75)
  buyingDate      DateTime @map("buying_date") @db.Date
  buyingLocation  String?  @map("buying_location") @db.VarChar(255)
  kilometerTarget Int      @map("kilometer_target")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workouts Workout[]

  @@index([userId])
  @@map("shoes")
}

model Workout {
  id         Int        @id @default(autoincrement())
  userId     Int        @map("user_id")
  type       WorkoutType
  startTime  DateTime   @map("start_time")
  endTime    DateTime   @map("end_time")
  steps      Int
  distanceKm Float      @map("distance_km")
  location   String     @db.VarChar(50)
  shoeId     Int?       @map("shoe_id")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoe Shoe? @relation(fields: [shoeId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([shoeId])
  @@map("workouts")
}

// Tracks applied test migrations (data-only, dev/stage). Do not use for app logic.
model TestMigration {
  name      String   @id
  appliedAt DateTime @default(now()) @map("applied_at")

  @@map("_test_migrations")
}
