{
  "name": "zapatismo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:generate": "npx prisma generate",
    "prisma:seed": "npx prisma db seed",
    "prisma:studio": "npx prisma studio",
    "prisma:reset": "npx prisma migrate reset",
    "prisma:reset:force": "npx prisma migrate reset --force",
    "prisma:reset:full": "npx prisma migrate reset --force && NODE_ENV=development npm run prisma:test-migrations",
    "prisma:test-migrations": "ts-node scripts/run-test-migrations.ts",
    "e2e:frontend": "npm run e2e -w frontend"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "prisma": "^6.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1"
  }
}
