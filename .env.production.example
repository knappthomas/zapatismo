# Production environment – copy to .env.production on the server and set values.
# Used by: docker-compose.production.yml

# --- Docker Compose (image pull) ---
REGISTRY_IMAGE_PREFIX=ghcr.io/YOUR_ORG/zapatismo

# --- MySQL (used by mysql-prod service; omit if using external Managed MySQL) ---
MYSQL_ROOT_PASSWORD=set-a-secure-password
MYSQL_DATABASE=zapatismo

# --- Backend (backend-prod service) ---
# With compose MySQL: mysql://root:PASSWORD@mysql-prod:3306/zapatismo
# With external DB: use the managed MySQL connection string.
DATABASE_URL=mysql://root:YOUR_MYSQL_ROOT_PASSWORD@mysql-prod:3306/zapatismo

JWT_SECRET=set-a-strong-production-jwt-secret
JWT_EXPIRATION=1h

# --- General ---
FRONTEND_URL=https://zapatismo.priorlaga.com

# Strava API
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_CALLBACK_URL=https://YOUR_DOMAIN/api/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=optional-webhook-verify-token
