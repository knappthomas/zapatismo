# Staging environment – copy to .env.staging on the server and set values.
# Used by: docker-compose.staging.yml

# --- Docker Compose (image pull) ---
# GitHub Container Registry prefix for staging images (e.g. ghcr.io/myorg).
REGISTRY_IMAGE_PREFIX=ghcr.io/YOUR_ORG/zapatismo

# --- MySQL (used by mysql-staging service) ---
MYSQL_ROOT_PASSWORD=set-a-secure-password
MYSQL_DATABASE=zapatismo

# --- Backend (backend-staging service) ---
# Connection to staging MySQL (use service name as host).
DATABASE_URL=mysql://root:YOUR_MYSQL_ROOT_PASSWORD@mysql-staging:3306/zapatismo

# JWT signing secret (use a strong value in staging).
JWT_SECRET=set-a-secure-jwt-secret
# Optional; default is 1h.
JWT_EXPIRATION=1h

# Strava API (create an app at https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
# OAuth callback URL (must match Strava app; e.g. https://staging.domain/api/strava/callback).
STRAVA_CALLBACK_URL=https://staging.YOUR_DOMAIN/api/strava/callback
# Optional: for Strava webhook subscription verification.
STRAVA_WEBHOOK_VERIFY_TOKEN=optional-webhook-verify-token
